<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- PROFILE IMAGE -->
        <ImageView
            android:id="@+id/imgProfileEdit"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_profile"
            android:background="@drawable/circle_bg"
            android:scaleType="centerCrop"/>

        <Button
            android:id="@+id/btnEditPhoto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Edit Photo"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"/>

        <!-- ABOUT -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="About Me"
            android:textStyle="bold"
            android:layout_marginTop="12dp"
            android:layout_gravity="center"/>

        <EditText
            android:id="@+id/etAbout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="About Me"/>

        <!-- PERSONAL -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Personal Info"
            android:textStyle="bold"/>

        <EditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Name"/>

        <EditText
            android:id="@+id/etCity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="City"/>

        <EditText
            android:id="@+id/etAge"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Age"/>

        <EditText
            android:id="@+id/etHeight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Height"/>

        <!-- RELIGION -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Religion Info"
            android:textStyle="bold"/>

        <EditText
            android:id="@+id/etReligion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Religion"/>

        <EditText
            android:id="@+id/etCaste"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Caste"/>

        <!-- EDUCATION -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Education Info"
            android:textStyle="bold"/>

        <EditText
            android:id="@+id/etEducation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Education"/>

        <EditText
            android:id="@+id/etOccupation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Occupation"/>

        <!-- FAMILY -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Family Info"
            android:textStyle="bold"/>

        <EditText
            android:id="@+id/etFatherOcc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Father Occupation"/>

        <EditText
            android:id="@+id/etMotherOcc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Mother Occupation"/>

        <!-- PARTNER -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Partner Preference"
            android:textStyle="bold"/>

        <EditText
            android:id="@+id/etPartnerAge"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Partner Age Range"/>

        <EditText
            android:id="@+id/etPartnerReligion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Partner Religion"/>

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Profile"
            android:layout_marginTop="20dp"/>

    </LinearLayout>
</ScrollView>
