<?xml version="1.0" encoding="utf-8"?>
<set xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Fade in -->
    <alpha
        android:fromAlpha="0.0"
        android:toAlpha="1.0"
        android:duration="1500"/>

    <!-- Move from bottom to center -->
    <translate
        android:fromYDelta="100"
        android:toYDelta="0"
        android:duration="1500"/>

</set>
